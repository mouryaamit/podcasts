{
  "name": "angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "sumpoorn",
  "sourceRoot": "apps/angular/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/sumpoorn_ui",
        "index": "apps/angular/src/index.html",
        "main": "apps/angular/src/main.ts",
        "polyfills": "apps/angular/src/polyfills.ts",
        "tsConfig": "apps/angular/tsconfig.app.json",
        "assets": [
          "apps/angular/src/favicon.ico",
          "apps/angular/src/assets",
          "apps/angular/src/robots.txt"
        ],
        "styles": [
          "node_modules/bootstrap/dist/css/bootstrap.css",
          "node_modules/aos/dist/aos.css",
          "node_modules/ngx-toastr/toastr.css",
          "node_modules/@angular/material/prebuilt-themes/deeppurple-amber.css",
          "apps/angular/src/styles.scss"
        ],
        "scripts": [
          "node_modules/bootstrap/dist/js/bootstrap.js"
        ],
        "allowedCommonJsDependencies": [
          "crypto-js",
          "xss",
          "d3",
          "file-saver"
        ]
      },
      "configurations": {
        "production": {
          "optimization": {
            "scripts": false,
            "styles": true,
            "fonts": true
          },
          "buildOptimizer": false,
          "vendorChunk": false,
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "outputHashing": "all",
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "10mb"
            }
          ],
          "fileReplacements": [
            {
              "replace": "apps/angular/src/environments/environment.ts",
              "with": "apps/angular/src/environments/environment.production.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/angular/src/environments/environment.ts",
              "with": "apps/angular/src/environments/environment.development.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "browserTarget": "angular:build:production"
        },
        "development": {
          "browserTarget": "angular:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": [
          "apps/angular/**/*.ts",
          "apps/angular/**/*.html"
        ]
      }
    }
  }
}