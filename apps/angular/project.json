{
  "name": "angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "sumpoorn",
  "sourceRoot": "apps/angular/src",
  "tags": [],
  "targets": {
     "prebuild": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/strip-exif.js && node tools/scripts/timestamp.js"
      }
    },
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "dependsOn": ["prebuild"],
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/angular",
        "index": "apps/angular/src/index.html",
        "main": "apps/angular/src/main.ts",
        "inlineStyleLanguage": "scss",
        "polyfills": "apps/angular/src/polyfills.ts",
        "tsConfig": "apps/angular/tsconfig.app.json",
        "buildOptimizer": false,
        "optimization": false,
        "vendorChunk": true,
        "extractLicenses": false,
        "sourceMap": true,
        "namedChunks": true,
        "assets": [
          "apps/angular/src/favicon.ico",
          "apps/angular/src/assets",
          "apps/angular/src/robots.txt"
        ],
        "allowedCommonJsDependencies": [
          "crypto-js",
          "xss",
          "d3",
          "file-saver"
        ],
        "styles": [
          {
            "input": "./node_modules/bootstrap/dist/css/bootstrap.css",
            "inject": true,
            "bundleName": "lib-bootstrap"
          },
          {
            "input": "./node_modules/aos/dist/aos.css",
            "inject": true,
            "bundleName": "lib-aos"
          },
          {
            "input": "node_modules/ngx-toastr/toastr.css",
            "inject": true,
            "bundleName": "lib-toastr"
          },
          {
            "input": "./node_modules/@angular/material/prebuilt-themes/deeppurple-amber.css",
            "inject": true,
            "bundleName": "lib-deeppurple"
          },
          "apps/angular/src/styles.scss"
        ],
        "scripts": [
          "./node_modules/bootstrap/dist/js/bootstrap.js"
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "10mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "12kb",
              "maximumError": "54kb"
            }
          ],
          "index": {
            "input": "apps/angular/src/index-prod.html",
            "output": "index.html"
          },
          "fileReplacements": [
            {
              "replace": "apps/angular/src/environments/environment.ts",
              "with": "apps/angular/src/environments/environment.production.ts"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "fileReplacements": [
            {
              "replace": "apps/angular/src/environments/environment.ts",
              "with": "apps/angular/src/environments/environment.development.ts"
            }
          ],
          "outputHashing": "all"
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "dependsOn": ["prebuild"],
      "configurations": {
        "production": {
          "browserTarget": "angular:build:production"
        },
        "development": {
          "browserTarget": "angular:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "browserTarget": "angular:build"
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "apps/angular/**/*.ts",
          "apps/angular/**/*.html"
        ]
      }
    }
  }
}