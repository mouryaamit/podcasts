{
  "name": "podcast",
  "projectType": "application",
  "root": "apps/podcast",
  "sourceRoot": "apps/podcast/lib",
  "targets": {
    "serve": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "command": "flutter run",
        "cwd": "apps/podcast"
      }
    },
    "build-web": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "cwd": "apps/podcast"
      },
      "configurations": {
        "development": {
          "command": "flutter build web --output ../../dist/sumpoorn_ui"
        },
        "production": {
          "command": "flutter build web --output ../../dist/sumpoorn_ui --release"
        }
      }
    },
    "build-android": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "command": "flutter build apk",
        "cwd": "apps/podcast"
      }
    },
    "build-ios": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "command": "flutter build ios",
        "cwd": "apps/podcast"
      }
    }
  },
  "tags": []
}