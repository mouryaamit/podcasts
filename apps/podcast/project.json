{
  "name": "podcast",
  "projectType": "application",
  "root": "apps/podcast",
  "sourceRoot": "apps/podcast/lib",
  "tags": [],

  "targets": {

    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter run -d chrome --web-port=4200",
        "cwd": "apps/podcast"
      }
    },

    "build-web": {
      "executor": "nx:run-commands",

      "options": {
        "cwd": ".",
        "parallel": false
      },

      "configurations": {

        "development": {
          "command": "node tools/scripts/build.js podcast DEV"
        },

        "production": {
          "command": "node tools/scripts/build.js podcast PROD"
        }

      }
    },

    "build-android": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter build apk --release",
        "cwd": "apps/podcast"
      }
    },

    "build-ios": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter build ios --release",
        "cwd": "apps/podcast"
      }
    }

  }
}