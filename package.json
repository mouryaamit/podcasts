{
  "name": "sumpoorn",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "nxReset":"nx reset",
    "start": "nx run angular:serve:development",
    "startProd": "nx run angular:serve:production",
    "updateTimeStamp": "node tools/scripts/timestamp.js",
    "_buildDev":"nx run podcast:build-web:development",
    "buildDev": "npm run updateTimeStamp -- angular:build:development & nx run angular:build:development",
    "buildProd": "npm run updateTimeStamp -- angular:build:production & nx run angular:build:production",
    "serve:angular:development": "nx run angular:serve:development",
    "build:angular:development": "nx run angular:build:development --base-href / --aot && node tools/scripts/inject-nonce.js sumpoorn_ui",
    "build:angular:production": "nx run angular:build:production --base-href / --aot && node tools/scripts/inject-nonce.js sumpoorn_ui",
    "update:podcast:production": "dotenv -e .env -- flutterflow export-code --project sumpoorn-yy3mxu --no-parent-folder -d apps/podcast --project-environment Production --branch-name feature-podcast --include-assets",
    "serve:podcast:development": "nx run podcast:serve:development",
    "build:podcast:development": "nx run podcast:build-web:development && node tools/scripts/inject-nonce.js resources_ui",
    "build:podcast:production": "nx run podcast:build-web:production"

  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/build-angular": "^14.2.13",
    "@angular-devkit/core": "^14.2.13",
    "@angular-devkit/schematics": "^14.2.13",
