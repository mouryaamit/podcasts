    "@angular-eslint/template-parser": "14.4.0",
    "@angular/cli": "~14.2.13",
    "@angular/compiler-cli": "^14.2.0",
    "@angular/language-service": "^14.2.13",
    "@nrwl/angular": "^15.9.7",
